# PlexusBeam Marketing Site — Environment Variables

# --- Required ---
# Supabase (service role only — never expose anon key)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# IP hash salt (change this to a random string)
IP_HASH_SALT=change-me-to-a-random-string

# Public site URL (for OG Images, metadata)
PUBLIC_SITE_URL=http://localhost:3000

# --- Optional ---
# Resend API key (for waitlist confirmation emails)
# If not set, the API still returns success but skips email
RESEND_API_KEY=re_xxx

# Contact email (used in footer and legal pages)
CONTACT_EMAIL=hello@plexusbeam.com
